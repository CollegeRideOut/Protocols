{
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,

  "semi": true,
  "singleQuote": true,
  "quoteProps": "consistent",

  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",

  "endOfLine": "lf",

  "proseWrap": "never",

  "overrides": [
    {
      "files": "*.json",
      "options": {
        "printWidth": 60
      }
    }
  ]
}
